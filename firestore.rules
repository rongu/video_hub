rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/artifacts/video-hub-prod-id/public/data/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 1. User List
    match /artifacts/{appId}/public/data/users/{userId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow write: if isAdmin();
      allow create: if request.auth != null; 
    }

    // 2. Enrollments
    match /artifacts/{appId}/public/data/enrollments/{enrollmentId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() 
                      || (request.auth != null 
                          && request.resource.data.userId == request.auth.uid 
                          && request.method in ['create', 'delete']);
    }

    // 3. Courses / Videos / Sessions
    match /artifacts/{appId}/public/data/courses/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Categories (MỚI)
    match /artifacts/{appId}/public/data/categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Dữ liệu riêng tư (Progress, v.v.)
    match /artifacts/{appId}/users/{userId}/{collectionName}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
