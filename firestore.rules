rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Kiểm tra user đã đăng nhập
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Kiểm tra role admin từ profile document
    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/artifacts/video-hub-prod-id/public/data/users/$(request.auth.uid)).data.role == 'admin';
    }

    // === PUBLIC DATA ===

    // Khóa học: mọi người đọc được, chỉ admin write
    match /artifacts/video-hub-prod-id/public/data/courses/{courseId} {
      allow read: if true;
      allow write: if isAdmin();

      match /sessions/{sessionId} {
        allow read: if true;
        allow write: if isAdmin();
      }

      match /videos/{videoId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Danh mục (categories): mọi người đọc được, chỉ admin write
    match /artifacts/video-hub-prod-id/public/data/categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Hồ sơ người dùng: user đã đăng nhập đọc được, chỉ chính chủ hoặc admin write
    match /artifacts/video-hub-prod-id/public/data/users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Ghi danh (enrollments): user đăng nhập đọc được, admin write
    match /artifacts/video-hub-prod-id/public/data/enrollments/{enrollmentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // === USER PRIVATE DATA ===

    // Tiến độ học (progress): chỉ chính chủ đọc/write
    match /artifacts/video-hub-prod-id/users/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

  }
}
